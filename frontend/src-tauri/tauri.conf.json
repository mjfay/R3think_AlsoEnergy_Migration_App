{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "r3think Extraction Tool",
  "version": "0.1.0",
  "identifier": "com.r3thinklabs.migration-tool",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "r3think Extraction Tool",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../backend/dist/alsoenergy-backend": "alsoenergy-backend"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
